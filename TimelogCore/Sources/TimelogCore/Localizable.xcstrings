    "Welcome back!" : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bentornato!"
          }
        }
      }
    },
    "What are you working on?" : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Su cosa stai lavorando?"
          }
        }
      }
    },
    "Wide range of activity types" : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ampia gamma di tipi di attività"
          }
        }
      }
    },
    "You balance steady sessions with creative flexibility. Deep work is important to you, though you adapt across a few areas." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bilanci sessioni regolari con flessibilità creativa. Il deep work è importante per te, ma ti adatti in diverse aree."
          }
        }
      }
    },
    "You deserve a long break. Stand up and stretch." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meriti una pausa lunga. Alzati e stiracchiati."
          }
        }
      }
    },
    "You had %lld very short sessions this week. Try protecting longer focus blocks." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa settimana hai avuto %lld sessioni molto brevi. Prova a proteggere blocchi di focus più lunghi."
          }
        }
      }
    },
    "You manage many moving parts — multiple clients and labels. You're the connective tissue that keeps everything running." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gestisci molti elementi in movimento — clienti ed etichette diverse. Sei il collante che tiene tutto in funzione."
          }
        }
      }
    },
    "You sample broadly across topics and tasks. Your strength is versatility, though longer focus blocks might boost your output." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esplori un'ampia varietà di argomenti e attività. Il tuo punto di forza è la versatilità, ma blocchi di focus più lunghi potrebbero migliorare la produttività."
          }
        }
      }
    },
    "You switched between %lld labels this week. Batching similar work can reduce context switching." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa settimana hai alternato %lld etichette. Raggruppare lavori simili può ridurre i cambi di contesto."
          }
        }
      }
    },
    "You there?" : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ci sei?"
          }
        }
      }
    },
    "You thrive in long, uninterrupted sessions. Your work is deep and focused, with few context switches." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eccelli in sessioni lunghe e senza interruzioni. Il tuo lavoro è profondo e concentrato, con pochi cambi di contesto."
          }
        }
      }
    },
    "You tracked less time than last week. Check if any sessions were missed." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai tracciato meno tempo rispetto alla settimana scorsa. Controlla se mancano sessioni."
          }
        }
      }
    },
    "You're not tracking anything" : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non stai tracciando nulla"
          }
        }
      }
    },
    "Your mind is recharged. Let's dive in." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La mente è ricaricata. Diamoci dentro."
          }
        }
      }
    },
    "Your office hours are ending. Log your time before you go." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'orario di lavoro sta per finire. Registra le tue ore prima di andare."
          }
        }
      }
    },
    "Your work style is well-rounded — a healthy mix of focus and flexibility across your tracked activities." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo stile di lavoro è equilibrato — un sano mix di focus e flessibilità nelle attività tracciate."
          }
        }
      }
    }
  },
  "version" : "1.1"
}