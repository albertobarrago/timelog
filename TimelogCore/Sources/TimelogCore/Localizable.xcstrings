        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il Bilanciato"
          }
        }
      }
    },
    "The break did its job. Now it's your turn." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
