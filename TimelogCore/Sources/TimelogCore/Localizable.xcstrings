            "value" : "L'Esploratore"
          }
        }
      }
    },
    "The long break did its job. Let's get back on track." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pausa lunga è servita. Rimettiamoci in carreggiata."
