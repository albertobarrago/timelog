    },
    "Tap + to log time or ▶ to start tracking": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi + per registrare o ▶ per avviare il tracciamento"
          }
        }
      }
    },
    "Tap ▶ to start a session when you begin working. Stop it when you're done — duration is logged automatically. You can run multiple sessions at once.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi ▶ per avviare una sessione quando inizi a lavorare. Fermala quando hai finito — la durata viene registrata automaticamente. Puoi avere più sessioni contemporaneamente."
          }
        }
      }
    },
    "Th": {
      "comment": "Day abbreviation - Thursday",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gi"
          }
        }
      }
    },
    "The simple way to track your team's time. No complexity, just results.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il modo più semplice per tracciare il tempo del tuo team. Senza complessità, solo risultati."
          }
        }
      }
    },
    "This will permanently delete all time entries and active sessions. This action cannot be undone.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa azione eliminerà definitivamente tutte le voci e le sessioni attive. Non può essere annullata."
          }
        }
