    "Tap + in Today to add a time entry. Pick client, project, duration — done.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premi + in Oggi per aggiungere una voce. Scegli cliente, progetto, durata — fatto."
          }
        }
      }
    },
