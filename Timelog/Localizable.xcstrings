    "The simple way to track your team's time. No complexity, just results.": {
      "extractionState": "stale",
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il modo più semplice per tracciare il tempo del tuo team. Senza complessità, solo risultati."
